# Also defined in .zprofile on purpose: each file must work standalone
# (non-login shells never read .zprofile). Matches functions/aliases too,
# unlike whence -p / $+commands — do not "simplify".
function command_exists(){
    type $1 2>/dev/null | grep -vq ' not found'
}

