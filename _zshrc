# Tool to check the timing of the config file, handy for debugging
T=0
t(){
    T="$(gdate +%s%N)"
}
td(){
    # Time delta
    TD="$(($(gdate +%s%N)-T))"
    # Milliseconds
    M="$((TD/1000000))"
    echo -n "Time in milliseconds: ${M}"

    if [ 0 = "$#" ]; then
        echo
    else
        echo " for $@"
    fi
    t
}

