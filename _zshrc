_uv_tmux_name(){
    if [ -n "$TMUX" ] && [ -n "$VIRTUAL_ENV" ]; then
        session_name=${VIRTUAL_ENV%/.venv}
        session_name=${session_name##*/}
        export PS1="($session_name)$ORIGINAL_PS1"
        echo -ne "\e]0;$session_name\a"
    fi
}

_activate_file(){
    activate_file="$1"
    if [ -f "$activate_file" ]; then
        echo "Activating using $PWD/${activate_file#./}"
        . "$activate_file"
        export PYTHONDONTWRITEBYTECODE=1
        _uv_tmux_name
        return 0
    fi
    return 1
}

activate(){
    if [ -n "$VIRTUAL_ENV" ]; then
        return 0
    fi

    _activate_file ./activate && return 0
    _activate_file ./.venv/bin/activate && return 0
    return 1
}


