function mosh(){
    if [ -n "$1" ]; then
        title "$1"
    fi
    command mosh $@
    title ""
}

# Little trick to change the name of the shell
function ssh(){
    if [[ "$@" =~ "BatchMode" ]]; then
        /usr/bin/ssh $*
        return
    fi
    local arg host="" skip_next=0
    for arg in "$@"; do
        if (( skip_next )); then skip_next=0; continue; fi
        case "$arg" in
            -[BbcDEeFIiJLlmOopQRSWw])      skip_next=1; continue;;
            -[BbcDEeFIiJLlmOopQRSWw]*|-*)  continue;;
            *) host="${arg##*@}"; break;;
        esac
    done
    [ -n "$1" ] && title "$*"
    local prev_color="$_TAB_COLOR_RGB"
    [ -n "$host" ] && (( $+functions[tab_color_from_string] )) && tab_color_from_string "$host"
    /usr/bin/ssh $*
    (( $+functions[tab_color_restore] )) && tab_color_restore "$prev_color"
    title ""
}


function autossh(){
    if [ -n "$1" ]; then
        title "$1"
    fi
    monitor_port=$((RANDOM % (65000 - 20000) + 20000))
    exec autossh -o ControlMaster=no -M $monitor_port $*
}

# Little function to go to a random directory, handy if you have a lot of
# stuff to sort out and don't know where to start ;)
torandomdir(){
    files=(*(/))
    dir=("${files[RANDOM%${#files[@]}]}")
    cd "$dir"
}

torandomparentdir(){
    cd ..
    echo "$PWD"
    torandomdir
}

random_select(){
    emulate -L zsh
    (( $# )) || return 1

    zmodload zsh/datetime 2>/dev/null
    zmodload zsh/system 2>/dev/null

    local random_seed random_index
    random_seed=${EPOCHREALTIME//[^0-9]/}
    (( random_index = (RANDOM + ${sysparams[pid]:-0} + 10#${random_seed[-9,-1]:-0}) % $# + 1 ))
    print -r -- "${@[random_index]}"
}

random_run(){
    emulate -L zsh

    local -a command_args
    while (( $# )); do
        [[ "$1" == "::" ]] && { shift; break; }
        command_args+=("$1")
        shift
    done

    if (( ! ${#command_args} || ! $# )); then
        print -u2 'usage: random_run command [args ... {} ...] :: files...'
        return 2
    fi

    local selected inserted=0 i
    selected=$(random_select "$@") || return

    for i in {1..${#command_args}}; do
        if [[ "${command_args[i]}" == "{}" ]]; then
            command_args[i]="$selected"
            inserted=1
        fi
    done

    (( inserted )) || command_args+=("$selected")
    "${command_args[@]}"
}

mpvrandom(){
    emulate -L zsh

    local selected
    selected=$(random_select "$@") || return
    mpv -- "$selected"
}

