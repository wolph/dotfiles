#!/bin/sh
# Generate each AI tool's instruction file from a shared base + per-tool override.
#
# Source of truth lives in the repo:
#   agents/global.md   - the universal instruction body (edit this)
#   agents/<tool>.md   - optional per-tool override appended after the base
#
# Destinations (only the marker-delimited region is managed; anything outside
# it is preserved, e.g. Gemini's auto-appended "## Gemini Added Memories" tail):
#   claude -> ~/.claude/CLAUDE.md   (fully managed)
#   codex  -> ~/.codex/AGENTS.md    (fully managed)
#   gemini -> ~/.gemini/GEMINI.md   (managed region on top, memory tail preserved)
#
# Idempotent: re-running reproduces byte-identical output. Re-run after editing
# any agents/*.md file.
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
agents_dir="$repo_dir/agents"

START='<!-- dotfiles:agent-global:start -->'
END='<!-- dotfiles:agent-global:end -->'

# sync_one <tool> <destination> <preserve-existing-content: yes|no>
sync_one() {
    tool=$1
    dest=$2
    preserve=$3
    override="$agents_dir/$tool.md"

    mkdir -p "$(dirname -- "$dest")"
    tmp=$(mktemp)

    # Head: anything before the START marker (preserved). Empty when no marker.
    if [ -f "$dest" ] && grep -qF "$START" "$dest"; then
        awk -v s="$START" '$0==s{exit} {print}' "$dest" >> "$tmp"
    fi

    # Managed block.
    {
        printf '%s\n' "$START"
        printf '%s\n\n' "<!-- Generated by dotfiles/bin/sync-agent-config from agents/global.md + agents/$tool.md. Do not edit between these markers; edit the source and re-run. -->"
        cat "$agents_dir/global.md"
        if [ -s "$override" ]; then
            printf '\n'
            cat "$override"
        fi
        printf '%s\n' "$END"
    } >> "$tmp"

    # Tail: content after the END marker (preserved). On a first run with no
    # markers, keep the whole existing file below the block when preserve=yes.
    if [ -f "$dest" ] && grep -qF "$END" "$dest"; then
        awk -v e="$END" 'p{print} $0==e{p=1}' "$dest" >> "$tmp"
    elif [ "$preserve" = yes ] && [ -s "$dest" ]; then
        printf '\n' >> "$tmp"
        cat "$dest" >> "$tmp"
    fi

    mv "$tmp" "$dest"
    echo "synced $dest"
}

sync_one claude "$HOME/.claude/CLAUDE.md" no
sync_one codex  "$HOME/.codex/AGENTS.md"  no
sync_one gemini "$HOME/.gemini/GEMINI.md" yes
