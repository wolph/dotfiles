#!/usr/bin/env zsh

TMX_WORKSPACE_DIR="${TMX_WORKSPACE_DIR:-$HOME/workspace}"
export TMX_DISABLE_ITERM=1

#
# Tmux launcher
#
# See: https://gist.github.com/WoLpH/3163775
#
# Modified version of a script orginally found at:
#     http://github.com/brandur/tmux-extra
#     http://forums.gentoo.org/viewtopic-t-836006-start-0.html
#

# Works because zsh automatically trims by assigning to variables and passing
# arguments
trim() { echo $1; }

# List all sessions only if there is a server running
sessions=$(tmux ls 2> /dev/null)

# Clean up old sessions
old_sessions=$(echo "$sessions" \
    | grep -v '(attached)' \
    | awk -F ':' '{print $1}' \
    | grep -E -- '-[0-9]{14}$')

if [ -n "$old_sessions" ]; then
    echo "$old_sessions" | xargs -L1 tmux kill-session -t
fi

function available_sessions(){
    sessions=$(tmux ls 2> /dev/null | grep -Ei "^[a-z]")
    echo "Available sessions:"
    echo "$sessions" | grep -vE -- '-[0-9]{14}:'
    exit
}

if [[ -z "$1" ]]; then
    echo "Specify session name as the first argument"
    echo
    available_sessions
    exit
fi

# Only because I often issue `ls` to this script by accident
if [[ "$1" == "ls" ]]; then
    available_sessions
fi

base_session="$1"

function title(){
    if [ "$1" != "default" ]; then
        echo -ne "\033]0;$1\007"
        printf "\033k$1\033\\"
    fi
}

_tmx_prev_color="$_TAB_COLOR_RGB"
if test -n "$ITERM_PROFILE"; then
    echo -ne "\e]1;$base_session\a"
    if [ -r "$HOME/bin/iterm2_tab_color" ]; then
        source "$HOME/bin/iterm2_tab_color"
        tab_color_from_string "$base_session"
    fi
fi
# Set terminal name
title "$1"

# Start project sessions in ~/workspace/<session> when that directory exists.
project_path="${TMX_WORKSPACE_DIR%/}/$base_session"
tmux_cwd="$PWD"

if [ -d "$project_path" ]; then
    tmux_cwd="$project_path"
    export HISTFILE="$project_path/.zshhistory"
    if [ ! -f "$HISTFILE" ]; then
        cp ~/.zshhistory "$HISTFILE"
    fi
fi

# This actually works without the trim() on all systems except OSX
tmux_nb=$(trim `echo "$sessions" | grep "^$base_session:" | wc -l`)
if [[ "$tmux_nb" == "0" ]]; then
    echo "Launching tmux base session $base_session ..."
    rc="$tmux_cwd/.tmuxrc"
    if [ -f $rc ]; then
        (cd "$tmux_cwd" && . $rc)
    else
        echo creating

        # Always create detached first
        # Pass TMX_DISABLE_ITERM=1 explicitly to ensure it propagates to the session
        tmux -2 new-session -d -s "$base_session" -e "TMX_DISABLE_ITERM=1" -e "DISPLAY=$DISPLAY" -e "XAUTHORITY=$XAUTHORITY" -c "$tmux_cwd"

        if [ -t 0 ]; then
            tmux -2 attach-session -t $base_session
        fi
        echo created session
    fi
else
    # Make sure we are not already in a tmux session
    if [[ -z "$TMUX" ]]; then
        if [ ! -t 0 ]; then
            echo "Session $base_session exists. No TTY detected to attach."
            exit 0
        fi

        # Kill defunct sessions first
        old_sessions=$(tmux ls 2>/dev/null | egrep "^[0-9]{14}.*[0-9]+\)$" | cut -f 1 -d:)
        for old_session_id in $old_sessions; do
            tmux kill-session -t $old_session_id
        done

        echo "Launching copy of base session $base_session ..."
        # Session is is date and time to prevent conflict
        session_id="${base_session}-$(date +%Y%m%d%H%M%S)"

        # Create a new session (without attaching it) and link to base session
        # to share windows
        tmux new-session -d -t $base_session -s $session_id -e "DISPLAY=$DISPLAY" -e "XAUTHORITY=$XAUTHORITY"

        # Attach to the new session
        echo "Attaching tmux -2 attach-session -t $session_id"
        if [ -n "$DISPLAY" ]; then
            tmux set-environment -t "$base_session" DISPLAY "$DISPLAY"
        else
            tmux set-environment -t "$base_session" -u DISPLAY
        fi
        if [ -n "$XAUTHORITY" ]; then
            tmux set-environment -t "$base_session" XAUTHORITY "$XAUTHORITY"
        else
            tmux set-environment -t "$base_session" -u XAUTHORITY
        fi
        tmux -2 attach-session -t $session_id

        # When we detach from it, kill the session
        #tmux kill-session -t $session_id
    fi
fi

test -n "$ITERM_PROFILE" && echo -ne "\e]0;\a"
if test -n "$ITERM_PROFILE" && (( $+functions[tab_color_restore] )); then
    tab_color_restore "$_tmx_prev_color"
fi
