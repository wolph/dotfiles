#!/usr/bin/env zsh
# git-scan — security scans for staged changes and outgoing commits.
# Wired into git via lefthook (see lefthook.yml); also usable standalone.
#
#   git-scan secrets --staged | --range [ref]
#   git-scan paths   --staged | --range [ref]
#   git-scan names   <file...>
#   git-scan syntax  <file...>
#
# Exit codes: 0 = clean, 1 = findings, 2 = usage error.
set -u

SENSITIVE_NAME_PATTERNS=(
    '.env' '.env.*' '*.pem' '*.key' '*.p12' '*.pfx'
    'id_rsa*' 'id_ed25519*' '*.sparseimage'
    '*history' '*_history' 'credentials*' '*.keychain'
)

MACHINE_PATH_PATTERN='/(Users|home)/[A-Za-z0-9._-]+'

SECRET_PATTERN="(ghp_[A-Za-z0-9]{20,}|gho_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9_-]{16,}|AKIA[0-9A-Z]{16}|xox[baprs]-[A-Za-z0-9-]{10,}|AIza[A-Za-z0-9_-]{30,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|eyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{10,}|(api[_-]?key|secret|password|token)[[:space:]]*[:=][[:space:]]*['\"][^'\"]{8,})"

# Diff-mode arguments must be validated before emit_diff runs inside a
# pipeline: usage()'s exit 2 would otherwise die in the pipe subshell and the
# pipeline would report a misleading 0.
require_diff_mode() {
    case "${1:-}" in
        (--staged|--range) ;;
        (*) usage ;;
    esac
}

# Print the unified-0 diff selected by --staged or --range. --range without a
# ref uses @{push}..HEAD; with no push ref it falls back to every commit
# missing from all remotes (new branch / no upstream).
emit_diff() {
    local mode="${1:-}" ref="${2:-}"
    case "$mode" in
        (--staged)
            git diff --cached --unified=0 --no-color
            ;;
        (--range)
            if [ -z "$ref" ] && git rev-parse --quiet --verify '@{push}' > /dev/null 2>&1; then
                ref='@{push}..HEAD'
            fi
            if [ -n "$ref" ]; then
                git diff --unified=0 --no-color "$ref"
            else
                git log --patch --unified=0 --no-color --pretty=format: HEAD --not --remotes
            fi
            ;;
        (*)
            usage
            ;;
    esac
}

# Read a unified-0 diff on stdin; print "file:line: content" for added lines
# matching the ERE in $1. Lines containing the literal marker $2 are allowed.
# Returns 1 if anything matched.
match_added_lines() {
    local pattern="$1" allow_marker="${2:-}"
    local line file='' lineno=0 hits=0 content
    while IFS= read -r line; do
        case "$line" in
            ('+++ b/'*) file="${line#+++ b/}" ;;
            ('+++ /dev/null') file='' ;;
            ('@@'*) lineno="${${line#*+}%%[ ,@]*}" ;;
            ('+'*)
                content="${line#+}"
                if [ -n "$file" ] && print -r -- "$content" | grep -qE "$pattern"; then
                    if [ -z "$allow_marker" ] || [[ "$content" != *"$allow_marker"* ]]; then
                        print -r -- "${file}:${lineno}: ${content}"
                        hits=$(( hits + 1 ))
                    fi
                fi
                lineno=$(( lineno + 1 ))
                ;;
        esac
    done
    (( hits == 0 ))
}

builtin_secret_scan() {
    emit_diff "$@" | match_added_lines "$SECRET_PATTERN"
}

scan_secrets() {
    require_diff_mode "${1:-}"
    local ret_status=0
    if command -v gitleaks > /dev/null 2>&1; then
        # Replaced with the real gitleaks invocation in the next task.
        builtin_secret_scan "$@" || ret_status=1
    else
        print -u2 'WARNING: gitleaks not installed - falling back to the weaker builtin secret scan.'
        print -u2 '         Install it with: brew install gitleaks'
        builtin_secret_scan "$@" || ret_status=1
    fi
    if (( ret_status != 0 )); then
        print -u2 'Potential secret found. False positive? Append "# gitleaks:allow" to the line'
        print -u2 'or extend the .gitleaks.toml allowlist. Bypass once with: LEFTHOOK=0 git commit'
    fi
    return $ret_status
}

scan_paths() {
    require_diff_mode "${1:-}"
    if ! emit_diff "$@" | match_added_lines "$MACHINE_PATH_PATTERN" '# path-ok'; then
        print -u2 'Machine-specific paths found. Use $HOME, or append "# path-ok" to allow a line.'
        print -u2 'Bypass once with: LEFTHOOK=0 git commit'
        return 1
    fi
    return 0
}

scan_names() {
    (( $# )) || return 0
    local f base pat hits=0
    for f in "$@"; do
        base="${f:t}"
        for pat in "${SENSITIVE_NAME_PATTERNS[@]}"; do
            if [[ "$base" == ${~pat} ]]; then
                print -r -- "blocked sensitive filename: ${f} (pattern: ${pat})"
                hits=$(( hits + 1 ))
                break
            fi
        done
    done
    if (( hits )); then
        print -u2 'Sensitive filenames must not be committed to this public repo.'
        print -u2 'Bypass once with: LEFTHOOK=0 git commit'
        return 1
    fi
    return 0
}

usage() {
    print -u2 'usage: git-scan secrets|paths --staged|--range [ref]'
    print -u2 '       git-scan names|syntax <file...>'
    exit 2
}

main() {
    (( $# >= 1 )) || usage
    local cmd="$1"
    shift
    case "$cmd" in
        (names)   scan_names "$@" ;;
        (paths)   scan_paths "$@" ;;
        (secrets) scan_secrets "$@" ;;
        (syntax)  usage ;;
        (*) usage ;;
    esac
}

main "$@"
