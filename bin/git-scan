#!/usr/bin/env zsh
# git-scan — security scans for staged changes and outgoing commits.
# Wired into git via lefthook (see lefthook.yml); also usable standalone.
#
#   git-scan secrets --staged | --range [ref]
#   git-scan paths   --staged | --range [ref]
#   git-scan names   <file...>
#   git-scan syntax  <file...>
#
# Exit codes: 0 = clean, 1 = findings, 2 = usage error.
set -u

SENSITIVE_NAME_PATTERNS=(
    '.env' '.env.*' '*.pem' '*.key' '*.p12' '*.pfx'
    'id_rsa*' 'id_ed25519*' '*.sparseimage'
    '*history' '*_history' 'credentials*' '*.keychain'
)

scan_names() {
    (( $# )) || return 0
    local f base pat hits=0
    for f in "$@"; do
        base="${f:t}"
        for pat in "${SENSITIVE_NAME_PATTERNS[@]}"; do
            if [[ "$base" == ${~pat} ]]; then
                print -r -- "blocked sensitive filename: ${f} (pattern: ${pat})"
                hits=$(( hits + 1 ))
                break
            fi
        done
    done
    if (( hits )); then
        print -u2 'Sensitive filenames must not be committed to this public repo.'
        print -u2 'Bypass once with: LEFTHOOK=0 git commit'
        return 1
    fi
    return 0
}

usage() {
    print -u2 'usage: git-scan secrets|paths --staged|--range [ref]'
    print -u2 '       git-scan names|syntax <file...>'
    exit 2
}

main() {
    (( $# >= 1 )) || usage
    local cmd="$1"
    shift
    case "$cmd" in
        (names)   scan_names "$@" ;;
        (secrets|paths|syntax) usage ;;
        (*) usage ;;
    esac
}

main "$@"
